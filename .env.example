# ============================================================
#  TracerStudy Alumni — Konfigurasi Environment
#  Salin file ini: cp .env.example .env
#  Lalu isi minimal SATU AI key di bawah
# ============================================================

# ── PILIHAN AI (isi salah satu atau lebih) ────────────────────
#  Prioritas otomatis: Gemini → Groq → Anthropic

# ── 1. Google Gemini (GRATIS ✓) ──────────────────────────────
#  Daftar: https://aistudio.google.com/app/apikey
#  Limit : 15 req/menit, 1 juta token/hari
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 2. Groq (GRATIS ✓) ───────────────────────────────────────
#  Daftar: https://console.groq.com/keys
#  Limit : 30 req/menit, model llama-3.3-70b
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 3. Anthropic Claude (Berbayar — ada web search) ──────────
#  Daftar: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────
#  Daftar: https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ── Server ────────────────────────────────────────────────────
PORT=3000
